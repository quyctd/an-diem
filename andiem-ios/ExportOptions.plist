<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Xcode 15.3+: "app-store-connect". Older Xcode: use "app-store". -->
  <key>method</key>
  <string>app-store-connect</string>
  <!-- Upload straight to App Store Connect / TestFlight on export. -->
  <key>destination</key>
  <string>upload</string>
  <key>teamID</key>
  <string>97J4X88D7H</string>
  <key>signingStyle</key>
  <string>automatic</string>
  <key>uploadSymbols</key>
  <true/>
  <!-- Keep the build number we set in project.yml; don't let Xcode rewrite it. -->
  <key>manageAppVersionAndBuildNumber</key>
  <false/>
</dict>
</plist>
